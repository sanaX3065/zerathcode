<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Review Automation Rule"
        android:textColor="@color/colorTextPrimary"
        android:textSize="17sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm this rule before it goes live."
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:paddingBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginBottom="16dp" />

    <!-- TRIGGER row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="14dp"
        android:gravity="top">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="TRIGGER"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingTop="2dp" />

        <TextView
            android:id="@+id/tvPreviewTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- CONDITION row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="14dp"
        android:gravity="top">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="CONDITION"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingTop="2dp" />

        <TextView
            android:id="@+id/tvPreviewCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ACTION row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="14dp"
        android:gravity="top">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="ACTION"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingTop="2dp" />

        <TextView
            android:id="@+id/tvPreviewAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorAccent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- PRIORITY row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="4dp"
        android:gravity="top">

        <TextView
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            android:text="PRIORITY"
            android:textColor="@color/colorTextSecondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingTop="2dp" />

        <TextView
            android:id="@+id/tvPreviewPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>